---
import type { SiteAriaCopy, SiteHeroCopy } from '../content/site';

interface Props {
  hero: SiteHeroCopy;
  aria: SiteAriaCopy;
}

const { hero, aria } = Astro.props;
---

<section class="hero">
  <div class="container hero-shell">
    <div class="hero-copy">
      <p class="eyebrow" data-i18n="hero.eyebrow">{hero.eyebrow}</p>

      <h1 class="title">
        <span class="title-line" data-i18n="hero.titleLead">{hero.titleLead}</span>
        <span class="title-muted">
          <span class="title-inline">
            <span data-i18n="hero.titleAccent">{hero.titleAccent}</span>
            <span class="cursor"></span>
          </span>
        </span>
      </h1>

      <p class="subtitle" data-i18n="hero.subtitle">
        {hero.subtitle}
      </p>

      <div class="cta-grid" data-onboarding-shell data-onboarding-version="stable">
        <div class="cta-head">
          <div
            class="cta-version-tabs"
            role="tablist"
            aria-label={hero.onboardingLabel}
            data-i18n-attr="aria-label:hero.onboardingLabel"
          >
            <button
              type="button"
              class="cta-version-tab is-active"
              role="tab"
              aria-selected="true"
              data-onboarding-version-tab="stable"
              data-i18n="hero.onboardingStableLabel"
            >
              {hero.onboardingStableLabel}
            </button>
            <button
              type="button"
              class="cta-version-tab"
              role="tab"
              aria-selected="false"
              data-onboarding-version-tab="beta"
              data-i18n="hero.onboardingBetaLabel"
              >
                {hero.onboardingBetaLabel}
              </button>
            </div>
        </div>
        <div class="cta-card surface-card">
          <p class="cta-label" data-i18n="hero.onboardingLabel">{hero.onboardingLabel}</p>
          <div class="cta-command">
            <code
              data-onboarding-command
              data-command-stable={hero.onboardingCommandStable}
              data-command-beta={hero.onboardingCommandBeta}
            >
              {hero.onboardingCommandStable}
            </code>
            <button
              type="button"
              class="copy-button"
              data-copy-button
              data-copy-text={hero.onboardingCommandStable}
              aria-label={aria.copyOnboarding}
              title={aria.copyOnboarding}
              data-i18n-attr="aria-label:aria.copyOnboarding;title:aria.copyOnboarding"
            >
              <svg class="copy-icon copy-icon-default" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M9 9a2 2 0 0 1 2-2h7a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-7a2 2 0 0 1-2-2z"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.7"
                />
                <path
                  d="M15 7V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h1"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.7"
                />
              </svg>
              <svg class="copy-icon copy-icon-success" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M20 7L10 17l-5-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                />
              </svg>
            </button>
          </div>
          <p class="sr-only" data-copy-feedback aria-live="polite"></p>
        </div>
      </div>

      <div class="beta-feature-wrap" data-beta-highlights hidden>
        <article class="beta-feature-card surface-card">
          <div class="beta-feature-head">
            <h2 class="highlight-title beta-feature-title" data-i18n="hero.betaFeature.title">
              {hero.betaFeature.title}
            </h2>
            <span class="beta-feature-badge">New</span>
          </div>
          <p class="highlight-description beta-feature-description" data-i18n="hero.betaFeature.description">
            {hero.betaFeature.description}
          </p>
        </article>
      </div>

      <div class="hero-highlights">
        {hero.highlights.map((highlight, index) => (
          <article class="highlight-card surface-card">
            <h2 class="highlight-title" data-i18n={`hero.highlights.${index}.title`}>
              {highlight.title}
            </h2>
            <p class="highlight-description" data-i18n={`hero.highlights.${index}.description`}>
              {highlight.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    min-height: calc(100dvh - 70px);
    padding: clamp(2.25rem, 5vh, 5rem) 0 clamp(1.6rem, 3.4vh, 3rem);
  }

  .hero-shell {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .hero-copy {
    width: min(100%, var(--content-rail));
    margin: 0 auto;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.22em;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .title {
    font-size: clamp(3.125rem, 4.7vw, 3.75rem);
    line-height: 1.08;
    max-width: 9.2ch;
    margin-bottom: 1rem;
  }

  .title-line {
    display: inline-block;
    white-space: nowrap;
  }

  .title-muted {
    display: block;
    color: var(--text-hero-muted);
    margin-top: 0.06em;
  }

  .title-inline {
    display: inline-flex;
    align-items: baseline;
    gap: 0.02em;
    white-space: nowrap;
  }

  .subtitle {
    font-size: clamp(1.0625rem, 1.4vw, 1.125rem);
    color: var(--text-dim);
    max-width: 576px;
    line-height: 1.79;
    margin-bottom: 1.5rem;
  }

  .cta-grid {
    width: min(100%, var(--content-rail));
    margin-bottom: 0.55rem;
  }

  .cta-grid[data-onboarding-version='beta'] {
    margin-bottom: 0.85rem;
  }

  .cta-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  .cta-version-tabs {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--button-bg);
  }

  .cta-version-tab {
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--text-dim);
    padding: 0.38rem 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .cta-version-tab:hover {
    color: var(--text);
  }

  .cta-version-tab.is-active {
    background: var(--button-active-bg);
    color: var(--text);
  }

  .cta-card {
    padding: 1rem 1rem 1.05rem;
    min-height: 132px;
    background: linear-gradient(180deg, var(--surface-elevated-start), var(--surface-elevated-end));
  }

  .hero-highlights {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    width: min(100%, var(--content-rail));
  }

  .beta-feature-wrap {
    width: min(100%, var(--content-rail));
    margin-bottom: 0.85rem;
  }

  .beta-feature-wrap[hidden] {
    display: none !important;
    margin: 0 !important;
  }

  .beta-feature-card {
    min-height: 0;
    padding: 1rem 1rem 1.05rem;
    opacity: 0;
    transform: translate3d(0, 18px, 0);
  }

  .beta-feature-wrap.is-visible .beta-feature-card {
    animation: beta-highlight-slide 0.46s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .beta-feature-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
    margin-bottom: 0.65rem;
  }

  .beta-feature-title {
    margin-bottom: 0;
  }

  .beta-feature-badge {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.24rem 0.56rem;
    border: 1px solid var(--button-active-border);
    border-radius: 999px;
    background: var(--button-active-bg);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .beta-feature-description {
    max-width: none;
  }

  .cta-label {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }

  .cta-card code {
    display: block;
    flex: 1;
    font-size: 0.96rem;
    color: var(--white-soft);
    line-height: 1.55;
    word-break: break-word;
  }

  .cta-command {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .copy-button {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    min-height: 34px;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 0.7rem;
    background: var(--button-bg);
    color: var(--white-soft);
    cursor: pointer;
    transition: background-color 0.2s, border-color 0.2s, color 0.2s;
  }

  .copy-icon {
    width: 16px;
    height: 16px;
  }

  .copy-icon-success {
    display: none;
  }

  .copy-button:hover {
    background: var(--button-hover-bg);
    border-color: var(--border-strong);
  }

  .copy-button.is-copied {
    color: var(--accent);
    background: var(--button-active-bg);
    border-color: var(--button-active-border);
  }

  .copy-button.is-copied .copy-icon-default {
    display: none;
  }

  .copy-button.is-copied .copy-icon-success {
    display: block;
  }

  .highlight-card {
    min-height: 140px;
    padding: 1rem 1rem 1.05rem;
    background: linear-gradient(180deg, var(--surface-elevated-start), var(--surface-elevated-end));
  }

  .highlight-title {
    font-size: 1rem;
    letter-spacing: -0.03em;
    margin-bottom: 0.6rem;
    color: var(--text);
  }

  @keyframes beta-highlight-slide {
    from {
      opacity: 0;
      transform: translate3d(0, 20px, 0);
    }

    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  .highlight-description {
    font-size: 0.95rem;
    line-height: 1.58;
    color: var(--text-dim);
  }

  @media (min-width: 900px) and (max-height: 980px) {
    .hero {
      min-height: calc(100dvh - 70px);
      padding-top: 1.7rem;
      padding-bottom: 1.25rem;
    }

    .eyebrow {
      margin-bottom: 0.85rem;
    }

    .title {
      font-size: clamp(3rem, 4.7vw, 3.75rem);
      line-height: 1.08;
      max-width: 9.2ch;
      margin-bottom: 0.9rem;
    }

    .subtitle {
      font-size: 1.0625rem;
      line-height: 1.79;
      max-width: 576px;
      margin-bottom: 1.35rem;
    }

    .cta-card {
      min-height: 122px;
      padding: 0.9rem 0.95rem 1rem;
    }

    .cta-label {
      margin-bottom: 0.8rem;
    }
  }

  @media (min-width: 900px) and (max-height: 860px) {
    .hero {
      padding-top: 1.2rem;
      padding-bottom: 1rem;
    }

    .title {
      font-size: clamp(3rem, 4.7vw, 3.75rem);
      line-height: 1.08;
      max-width: 9.2ch;
    }

    .subtitle {
      font-size: 1.125rem;
      line-height: 1.79;
      margin-bottom: 1.1rem;
    }

    .cta-card code {
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .highlight-card {
      min-height: 128px;
      padding: 0.95rem;
    }

    .highlight-title {
      font-size: 0.95rem;
      margin-bottom: 0.5rem;
    }

    .highlight-description {
      font-size: 0.9rem;
      line-height: 1.5;
    }
  }

  @media (max-width: 720px) {
    .hero-copy {
      width: 100%;
    }

    .title {
      font-size: clamp(2.75rem, 11vw, 3.35rem);
      max-width: 100%;
      text-wrap: balance;
    }

    .title-line {
      white-space: normal;
    }

    .title-inline {
      display: inline;
      white-space: normal;
    }

    .cta-command {
      flex-direction: column;
    }

    .cta-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .beta-feature-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero-highlights {
      grid-template-columns: 1fr;
    }

    .highlight-card {
      min-height: 0;
    }
  }

  @media (max-width: 560px) {
    .hero {
      padding-top: 4.2rem;
    }

    .title {
      font-size: clamp(2.4rem, 10.8vw, 3rem);
      line-height: 1.04;
    }

    .eyebrow {
      font-size: 0.74rem;
      letter-spacing: 0.2em;
    }

    .subtitle {
      font-size: 1.04rem;
    }
  }
</style>
