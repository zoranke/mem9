PORT=3101

# Internal address for mnemo-server inside Docker or NAS LAN.
MNEMO_BASE_URL=http://mnemo-server:8888

# Optional fallback API key used by the dashboard API when the browser does not
# send X-API-Key. For a single-tenant NAS deployment, set this to your tenant ID.
MEM9_API_KEY=replace-with-your-tenant-id

# SQLite audit log path.
AUDIT_DB_PATH=/data/audit/audit.db

# Optional Basic Auth for the dashboard API.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-this-password
