# Shared default for preview and real-API smoke checks.
# For local UI-first work, copy .env.local.example to .env.local instead.

# Local UI-first defaults.
# Keep the shared .env unchanged. Copy this file to .env.local for local work.
VITE_USE_MOCK=false
VITE_API_BASE=/your-memory/api
VITE_ANALYSIS_API_BASE=/your-memory/analysis-api
# Planned feature flags for UI-first work.
# They may be ignored until src/config/features.ts lands.
VITE_ENABLE_MANUAL_ADD=false
VITE_ENABLE_TIME_RANGE=false
VITE_ENABLE_FACET=true
VITE_ENABLE_TOPIC_SUMMARY=true
VITE_ENABLE_ANALYSIS=true
VITE_ANALYSIS_BATCH_SIZE=100
VITE_ANALYSIS_POLL_MS=1500
