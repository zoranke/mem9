MNEMO_PORT=8888
MNEMO_DB_BACKEND=tidb
MNEMO_DSN=USERNAME:PASSWORD@tcp(TIDB_HOST:4000)/mem9_home?tls=true&parseTime=true

MNEMO_UPLOAD_DIR=/data/mem9/uploads

MNEMO_RATE_LIMIT=30
MNEMO_RATE_BURST=60

MNEMO_TENANT_POOL_MAX_IDLE=2
MNEMO_TENANT_POOL_MAX_OPEN=5
MNEMO_TENANT_POOL_TOTAL_LIMIT=20
MNEMO_TENANT_POOL_IDLE_TIMEOUT=10m

MNEMO_WORKER_CONCURRENCY=2
MNEMO_INGEST_MODE=smart
MNEMO_FTS_ENABLED=false

MNEMO_EMBED_API_KEY=
MNEMO_EMBED_BASE_URL=
MNEMO_EMBED_MODEL=
MNEMO_EMBED_DIMS=1536

MNEMO_LLM_API_KEY=
MNEMO_LLM_BASE_URL=
MNEMO_LLM_MODEL=gpt-4o-mini
MNEMO_LLM_TEMPERATURE=0.1
